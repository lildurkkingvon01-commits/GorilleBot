# ==================== DISCORD BOT ====================
# Discord Bot Token (get it from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Client ID
DISCORD_CLIENT_ID=your_client_id_here

# Discord Guild IDs (for testing, comma-separated)
DISCORD_GUILD_IDS=123456789,987654321

# ==================== DATABASE ====================
# PostgreSQL Connection Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gorille_db
DB_USER=postgres
DB_PASSWORD=your_password_here
# Alternatively you can provide a single connection string (recommended for hosted DBs)
# Example: DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=
# If your hosted DB requires SSL and you want to accept the provider's certificate,
# set DB_SSL=true
DB_SSL=false

# ==================== API SERVICES ====================
# Main Bot API URL - used for guild actions, moderation, analytics
# The API service runs on port 4000 by default (see apps/api/src/main.ts)
API_URL=http://localhost:4000

# Optional: Web Panel URL (if running separately on port 3000)
WEB_PANEL_URL=http://localhost:3000

# Optional: Bot WebSocket URL (for real-time updates on port 3001)
BOT_WS_URL=http://localhost:3001

# ==================== NODE ENVIRONMENT ====================
NODE_ENV=development
# Options: development, production

# ==================== LOGGING & DEBUG ====================
# Enable detailed guild actions polling logs
# Set to true to see: [GUILD ACTIONS] Polling: http://localhost:4000/api/bot/guild-actions
DEBUG_GUILD_ACTIONS=false

# Log level for API server
LOG_LEVEL=info
# Options: error, warn, info, debug

# ==================== GUILD ACTIONS POLLING ====================
# Polling interval in milliseconds (default: 10000 = 10 seconds)
GUILD_ACTIONS_POLL_INTERVAL=10000

# Request timeout in milliseconds (default: 5000 = 5 seconds)
GUILD_ACTIONS_TIMEOUT=5000

# ==================== FEATURES ====================
# Enable auto-moderation system
AUTOMOD_ENABLED=true

# Enable command logging
COMMAND_LOGGING_ENABLED=true

# Enable activity tracking
TRACKING_ENABLED=true

# ==================== PORT CONFIGURATION ====================
# Web Panel Port (if running separately)
# PORT=3000

# API Server Port (set in apps/api/.env or here)
# API_PORT=4000

# ==================== PM2 CONFIGURATION (Optional) ====================
# If using PM2 on Windows and getting "spawn wmic ENOENT" errors:
# Uncomment the line below to disable CPU monitoring
# PM2_DISABLE_MONITORING=true